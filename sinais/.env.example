# Base de dados (Railway: usar DATABASE_URL=${{Postgres.DATABASE_URL}} nas Variables)
# Local: postgresql://user:pass@localhost:5432/sinais
DATABASE_URL="postgresql://user:pass@localhost:5432/sinais"

# Segredo para cron jobs (cron-job.org, etc.)
CRON_SECRET=seu-token-seguro-aqui

# Código de acesso à app (obrigatório se AUTH_DISABLED não for true)
ACCESS_CODE=

# Acesso sem login quando true (útil para testes). false ou omitir = login obrigatório
# AUTH_DISABLED=true

# ─── Trading ──────────────────────────────────────────────────────────────────
# Exchange activa: "binance" (default) ou "bybit"
EXCHANGE=binance

# Tamanho da posição em USDT (default 100)
POSITION_SIZE_USDT=100

# Activa ordens reais (true/false). Sempre requer Testnet configurado.
TRADING_ENABLED=false

# Força mínima para auto-exec (default 80)
AUTO_EXECUTE_MIN_STRENGTH=80

# ─── Binance Futures ──────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Testnet: https://testnet.binancefuture.com | Mainnet: https://fapi.binance.com
BINANCE_FUTURES_BASE_URL=https://testnet.binancefuture.com
# Proxy HTTP(S) para API pública Binance Futures (obrigatório se Railway US devolver 451)
# BINANCE_HTTP_PROXY=http://user:pass@host:port

# ─── Bybit Linear Futures ───────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Demo: https://api-demo.bybit.com | Testnet: https://api-testnet.bybit.com
# Mainnet (dinheiro real): https://api.bybit.com + obrigatório BYBIT_ALLOW_MAINNET=true
BYBIT_BASE_URL=https://api-demo.bybit.com
# Só para mainnet real — sem isto, o bot recusa api.bybit.com por segurança
BYBIT_ALLOW_MAINNET=false
# Host alternativo para klines públicos (se api.bybit.com bloquear o IP do servidor)
# BYBIT_MARKET_DATA_BASE_URL=https://api.bybit.nl
