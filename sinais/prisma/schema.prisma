// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Strategy {
  id          String   @id @default(cuid())
  name        String   @unique // ex: "RSI", "MA_CROSSOVER"
  displayName String   // ex: "RSI Sobrecomprado/Sobrevendido"
  description String
  isActive    Boolean  @default(true)
  params      String   @default("{}") // JSON string com parâmetros
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  signals Signal[]
}

model Signal {
  id           String   @id @default(cuid())
  symbol       String   // ex: "BTCUSDT"
  direction    String   // "BUY" | "SELL"
  timeframe    String   // ex: "1m", "5m", "1h"
  strategyId   String
  strategyName String   // denormalizado para facilitar leitura
  entryPrice   Float
  stopLoss     Float
  target1      Float?
  target2      Float?
  target3      Float?
  strength     Int      // 0-100
  status       String   @default("NEW") // "NEW" | "IN_PROGRESS" | "HIT_TARGET" | "HIT_STOP" | "EXPIRED"
  generatedAt  DateTime @default(now())
  lastCheckedAt DateTime?
  extraInfo    String?  // JSON string com detalhes do cálculo
  price24h     Float?   // Preço após 24 horas
  result24h    Float?   // Resultado após 24h (diferença de preço)
  status24h    String?  // "CLOSED" quando já passaram 24h, null caso contrário
  high24h       Float?   // Preço mais alto durante as 24 horas
  low24h        Float?   // Preço mais baixo durante as 24 horas
  // executedAt e executionOrderId removidos - BD sem essas colunas (adicionar depois via migration)

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([symbol])
  @@index([strategyId])
  @@index([generatedAt])
  @@index([status])
}

model TopVolatile {
  id               String   @id @default(cuid())
  symbol           String
  high3m           Float    // Máxima dos últimos 3 meses
  low3m            Float    // Mínima dos últimos 3 meses
  volatilityPercent Float   // (high3m - low3m) / low3m * 100
  lastPrice        Float?   // Preço atual no momento do cálculo
  rank             Int      // Posição 1-20
  updatedAt        DateTime @default(now())

  @@index([rank])
}

// Criptos com Preço < MA200 e MA30 > MA200 (potencial setup de retorno bullish)
model MaCrossBelow {
  id             String   @id @default(cuid())
  symbol         String
  lastPrice      Float    // Preço atual
  ma30           Float    // Média móvel de 30 períodos (diária)
  ma200          Float    // Média móvel de 200 períodos (diária)
  distPriceMa200 Float    // % que o preço está abaixo da MA200 (negativo)
  distMa30Ma200  Float    // % que a MA30 está acima da MA200 (positivo)
  rank           Int      // Ordenado por distMa30Ma200 desc
  updatedAt      DateTime @default(now())

  @@index([rank])
}

// Criptos com MA30 a mais de 6% acima da MA200 (1h) — força de tendência
model Ma30Above6Pct {
  id             String   @id @default(cuid())
  symbol         String
  lastPrice      Float
  ma30           Float
  ma200          Float
  distPriceMa200 Float
  distMa30Ma200  Float
  rank           Int
  updatedAt      DateTime @default(now())

  @@index([rank])
}

// Scan 1h SMA: MA30 entre −10% e −5% vs MA200 (tabela/nome legados Ma30Near6…)
model Ma30Near6PriceBetween {
  id             String   @id @default(cuid())
  symbol         String
  lastPrice      Float
  ma30           Float
  ma200          Float
  distPriceMa200 Float
  distMa30Ma200  Float
  rank           Int
  updatedAt      DateTime @default(now())

  @@index([rank])
}

